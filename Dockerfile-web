# 利用预编译镜像大幅缩短 Railway 构建时间，避免 512MB 内存爆满的问题
FROM ghcr.io/xinnan-tech/xiaozhi-esp32-server:web_latest

# 使用我们优化过的 Railway 启动脚本和 Nginx 配置
COPY docs/docker/start.sh /start.sh
COPY docs/docker/nginx.conf /etc/nginx/nginx.conf

# 修复执行权限
RUN chmod +x /start.sh

# 告诉 Railway 默认监听 8002
EXPOSE 8002

# 启动 (start.sh 已包含动态端口适配逻辑和数据库等待逻辑)
CMD ["/start.sh"]